# ===================================================
# シークレット設定（Secrets）
# ===================================================
# このファイルを .env.local にコピーして値を入力してください。
#   cp .env.local.sample .env.local
#
# .env.local は gitignore 対象です（絶対にコミットしないでください）。
# Vercel へのデプロイ時は、このファイルの内容を
# Vercel Dashboard → Settings → Environment Variables → Import .env
# で一括インポートできます。
#
# 非シークレット設定（サービス名・色・URL等）は .env に記入してください。
# ===================================================

# ─── Turso Database ───────────────────────────────────────────────────────────
# 取得先: https://turso.tech → DB選択 → Connect
TURSO_DATABASE_URL=libsql://your-db-name-yourname.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Better Auth ──────────────────────────────────────────────────────────────
# 生成方法: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-char-random-secret

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# 取得先: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Resend（メール送信）──────────────────────────────────────────────────────
# 取得先: https://resend.com → API Keys → Create
RESEND_API_KEY=re_your-resend-api-key

# ─── Stripe（決済）───────────────────────────────────────────────────────────
# 取得先: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Connected-accounts endpoint (account.updated) — separate endpoint, separate secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# ─── Cloudflare R2（シークレット部分のみ）────────────────────────────────────
# バケット名・公開URLは .env に記載
# 取得先: dash.cloudflare.com → R2 → Manage R2 API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key

# ─── Printful（印刷・発送）───────────────────────────────────────────────────
# 取得先: developers.printful.com → Tokens
PRINTFUL_API_KEY=your-printful-api-key
# 生成方法: openssl rand -hex 20
PRINTFUL_WEBHOOK_SECRET=your-webhook-secret
# 注文の自動確定（省略時 = 自動確定ON・Printful に支払い方法の登録が必須）。
# "false" にすると注文はドラフトで止まり、Printful 画面での手動確定が必要になる
# PRINTFUL_AUTO_CONFIRM=false

# ─── OpenAI（AIデザイン生成 — オプション）────────────────────────────────────
# 取得先: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# ─── Cron Jobセキュリティ ─────────────────────────────────────────────────────
# 生成方法: openssl rand -hex 32
CRON_SECRET=your-cron-secret
